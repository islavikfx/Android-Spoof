<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/draw_panel">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <ImageView
            android:id="@+id/app_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@null" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/app_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />
            <TextView
                android:id="@+id/app_pkg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:id="@+id/app_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />
    <TextView
        android:id="@+id/app_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />
    <TextView
        android:id="@+id/app_perms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/warning_app_delete"
        android:textColor="#FF9800"
        android:textSize="11sp"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/poppins_extrabold" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:rowCount="2"
        android:columnCount="2">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/cancel"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:cornerRadius="26dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_forcestop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/force_stop"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:cornerRadius="26dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:text="@string/clear_data"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:cornerRadius="26dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_del"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="@string/delete_app"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:cornerRadius="26dp" />
    </GridLayout>
</LinearLayout>