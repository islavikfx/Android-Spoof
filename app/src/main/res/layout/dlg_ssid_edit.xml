<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/draw_panel">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enter_new_value"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/poppins_bold" />
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="12dp"
        app:strokeWidth="2dp">
        <EditText
            android:id="@+id/edit_val"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:hint="@string/type_here"
            android:autofillHints="no"
            android:fontFamily="@font/poppins_regular" />
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:id="@+id/txt_sel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/poppins_regular" />
    <TextView
        android:id="@+id/txt_cur"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/poppins_regular" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/warning_id_reset"
        android:textColor="#FF9800"
        android:textSize="11sp"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/poppins_extrabold" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply_reboot"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/apply_reboot"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/poppins_medium" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/action_apply"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/poppins_medium" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/cancel"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:cornerRadius="24dp"
        android:fontFamily="@font/poppins_medium" />
</LinearLayout>