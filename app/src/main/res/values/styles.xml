<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="OutlinedThemeButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="strokeWidth">2dp</item>
        <item name="strokeColor">#9C27B0</item>
        <item name="cornerRadius">28dp</item>
    </style>
    <style name="RoundedDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>
</resources>